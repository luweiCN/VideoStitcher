# 火山引擎 API 配置
# 请从火山引擎控制台获取 API Key
VOLCANO_ENGINE_API_KEY=your_api_key_here

# 可选：自定义 API 端点（默认使用火山引擎官方端点）
# VOLCANO_ENGINE_LLM_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3/chat
# VOLCANO_ENGINE_EMBEDDINGS_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3/embeddings

# 可选：模型配置
# VOLCANO_ENGINE_MODEL=doubao-pro-4k
# VOLCANO_ENGINE_EMBEDDINGS_MODEL=doubao-embedding
