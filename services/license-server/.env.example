# 本地监听配置
PORT=8787

# 首次登录用户名；首次登录成功后会创建所有者账号
LICENSE_BOOTSTRAP_ADMIN_USERNAME=owner

# 本地首次初始化可启用；TOS 生产环境只在首次建号时临时设为 true，完成后立即改为 false
LICENSE_ALLOW_ADMIN_BOOTSTRAP=true

# 首次登录密码的 SHA-256 摘要，不填写明文；创建所有者后不再作为通用口令使用
LICENSE_ADMIN_TOKEN_HASH=

# 设备指纹、隐藏设备凭据和 IP 哈希使用的服务端 pepper，至少 32 字节随机值
LICENSE_KEY_PEPPER=

# Ed25519 私钥，只放在火山引擎密钥管理或函数加密环境变量中
LICENSE_SIGNING_PRIVATE_KEY=

# 本地开发使用文件存储；生产环境设置为 tos
LICENSE_STORAGE_DRIVER=file
LICENSE_DATA_FILE=.data/licenses.json

# TOS 生产配置；veFaaS 绑定 IAM 角色后不需要填写永久 AK/SK
TOS_ACCESS_KEY=
TOS_SECRET_KEY=
TOS_STS_TOKEN=
TOS_REGION=cn-beijing
TOS_ENDPOINT=tos-cn-beijing.volces.com
TOS_BUCKET=
TOS_OBJECT_KEY=license-platform/state.json

# 可选：启用管理后台“发布新版本”。Token 只保存在服务端，不能下发到浏览器或客户端。
# Fine-grained Token 需要私有仓库 Metadata 读取、Contents 读取和 Actions 读写权限。
GITHUB_RELEASE_TOKEN=
GITHUB_RELEASE_REPOSITORY=luweiCN/VideoStitcher
GITHUB_RELEASE_REF=master
GITHUB_RELEASE_WORKFLOW=release.yml

# 管理后台直接切换 TOS 当前版本；生产环境优先使用函数 IAM 角色的临时凭证。
TOS_UPDATE_ACCESS_KEY_ID=
TOS_UPDATE_SECRET_ACCESS_KEY=
TOS_UPDATE_SESSION_TOKEN=
TOS_UPDATE_REGION=cn-beijing
TOS_UPDATE_ENDPOINT=tos-cn-beijing.volces.com
TOS_UPDATE_BUCKET=videostitcher-updates-prod
TOS_UPDATE_PREFIX=stable
VIDEO_STITCHER_UPDATE_BASE_URL=
